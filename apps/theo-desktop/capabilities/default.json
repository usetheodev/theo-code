{
  "$schema": "https://raw.githubusercontent.com/nicegui-org/nicegui/main/tauri/cap-schema.json",
  "identifier": "default",
  "description": "Default capabilities for Theo Code",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:event:default",
    "core:window:default",
    "core:window:allow-set-title",
    "shell:allow-open",
    "dialog:allow-open",
    "dialog:allow-save"
  ]
}
