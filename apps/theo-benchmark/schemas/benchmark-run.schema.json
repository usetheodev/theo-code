{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "theo.benchmark-run.v1",
  "title": "Theo Benchmark Run",
  "description": "Canonical schema for a single benchmark run result. All probe, smoke, and SWE-bench runners MUST emit data conforming to this schema.",
  "type": "object",
  "required": [
    "schema_version",
    "run_id",
    "model_id",
    "timestamp",
    "theo_sha",
    "task_id",
    "task_category",
    "pass",
    "duration_ms",
    "tokens",
    "cost_usd"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "theo.benchmark-run.v1",
      "description": "Schema version identifier"
    },
    "run_id": {
      "type": "string",
      "format": "uuid",
      "description": "Unique identifier for this run"
    },
    "model_id": {
      "type": "string",
      "description": "Model name (e.g., 'gpt-4o', 'claude-sonnet-4-5', 'qwen3-30b')"
    },
    "model_version": {
      "type": "string",
      "description": "Model version or snapshot date if known"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO-8601 timestamp of run start"
    },
    "theo_sha": {
      "type": "string",
      "pattern": "^[a-f0-9]{7,40}$",
      "description": "Git SHA of the theo binary used"
    },
    "task_id": {
      "type": "string",
      "description": "Task identifier (e.g., '01-read-answer', 'django__django-12345')"
    },
    "task_category": {
      "type": "string",
      "enum": [
        "cli-subcommand",
        "tool-smoke",
        "provider-auth",
        "graphctx",
        "smoke-read",
        "smoke-search",
        "smoke-fix-bug",
        "smoke-create",
        "smoke-rename",
        "smoke-analyze",
        "smoke-multi-file",
        "smoke-plan",
        "smoke-bash",
        "smoke-imports",
        "swe-bench-lite",
        "swe-bench-verified",
        "terminal-bench",
        "feature-agent"
      ],
      "description": "Category of the task for aggregation"
    },
    "benchmark_suite": {
      "type": "string",
      "enum": ["e2e-probe", "smoke", "swe-bench", "terminal-bench", "graphctx", "feature-agent"],
      "description": "Which benchmark suite this run belongs to"
    },
    "pass": {
      "type": "boolean",
      "description": "Whether the task passed its success criteria"
    },
    "pass_rate": {
      "type": "number",
      "minimum": 0.0,
      "maximum": 1.0,
      "description": "Pass rate if this is an aggregated result (otherwise same as pass: 0 or 1)"
    },
    "duration_ms": {
      "type": "integer",
      "minimum": 0,
      "description": "Total wall-clock duration in milliseconds"
    },
    "iterations": {
      "type": "integer",
      "minimum": 0,
      "description": "Number of agent loop iterations"
    },
    "convergence_rate": {
      "type": "number",
      "minimum": 0.0,
      "maximum": 1.0,
      "description": "Fraction of iterations that made progress"
    },
    "tokens": {
      "type": "object",
      "required": ["input", "output", "total"],
      "properties": {
        "input": { "type": "integer", "minimum": 0 },
        "output": { "type": "integer", "minimum": 0 },
        "total": { "type": "integer", "minimum": 0 },
        "cache_hits": { "type": "integer", "minimum": 0 },
        "reasoning": { "type": "integer", "minimum": 0 }
      }
    },
    "cost_usd": {
      "type": "number",
      "minimum": 0.0,
      "description": "Estimated cost in USD"
    },
    "context_bytes": {
      "type": "integer",
      "minimum": 0,
      "description": "Average context window size in bytes during this run"
    },
    "tool_calls": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["tool_id", "success"],
        "properties": {
          "tool_id": { "type": "string" },
          "success": { "type": "boolean" },
          "duration_ms": { "type": "integer", "minimum": 0 }
        }
      },
      "description": "Per-tool call results"
    },
    "subtask_results": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "pass"],
        "properties": {
          "id": { "type": "string" },
          "pass": { "type": "boolean" },
          "duration_ms": { "type": "integer", "minimum": 0 },
          "error": { "type": "string" }
        }
      },
      "description": "Per-subtask results for granular analysis"
    },
    "error": {
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "enum": ["none", "network", "llm", "tool", "sandbox", "budget", "validation", "timeout"]
        },
        "message": { "type": "string" }
      },
      "description": "Error details if the run failed"
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true,
      "description": "Arbitrary metadata (oracle mode, temperature, prompt variant, etc.)"
    }
  },
  "additionalProperties": false
}
